  "description": "Backend API for an Airbnb clone (accommodations, reservations, JWT auth) built with Node, Express and MongoDB.",
  "main": "server.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node scripts/seed.js"
